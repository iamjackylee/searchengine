# Copy this file to .env and update values for your machine.
# This file is gitignored — never commit real credentials.

# Only needed for optional self-host mode (app/ with Postgres)
DATABASE_URL=postgresql+psycopg2://YOUR_USER:YOUR_PASSWORD@localhost:5432/YOUR_DB

DEFAULT_SINCE_HOURS=24
INGEST_INTERVAL_MINUTES=15
GDELT_TIMESPAN=7d
SOURCES_FILE=data/sources.yaml
MAX_AGE_DAYS=30

# Optional security token for API/browser requests.
# If set, send header: X-API-Token: <value>
API_TOKEN=

# App bind config (only for self-host mode)
HOST=127.0.0.1
PORT=8000
