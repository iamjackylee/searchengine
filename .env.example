# Copy this file to .env and update values for your machine
DATABASE_URL=postgresql+psycopg2://ai_news:ai_news@localhost:5432/ai_news
DEFAULT_SINCE_HOURS=24
INGEST_INTERVAL_MINUTES=15
GDELT_TIMESPAN=7d
SOURCES_FILE=data/sources.yaml

# Optional security token for API/browser requests.
# If set, send header: X-API-Token: <value>
API_TOKEN=

# App bind config (used by start.sh)
HOST=127.0.0.1
PORT=8000
